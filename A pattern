a = [[" " for i in range(13)] for i in range(7)]
b = 6   
for i in range(7):
    if i == 0:
        a[i][b] = "*"
    else:
        a[i][b - i] = "*"
        a[i][b + i] = "*"
    for j in range(13):        
        if i==4 and 2<=j<=10:
            a[i][j]="*"
for i in range(7):
    for j in range(13):
        print(a[i][j], end=" ")
    print()
